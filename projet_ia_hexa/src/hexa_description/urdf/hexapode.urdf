<?xml version="1.0"?>
<robot name="scarabee_hexapode">



  <!-- BUSTE -->
  <link name="buste">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 3.1416"/>
      <geometry>
        <mesh filename="package://hexa_description/meshes/hexa_mesh_v2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="body_color">
        <color rgba="0.25 0.15 0.05 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://hexa_description/meshes/hexa_mesh_v2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="25.0"/>
      <inertia 
        ixx="0.026" ixy="0" ixz="0"
        iyy="0.052" iyz="0"
        izz="0.068"/>
    </inertial>
  </link>


